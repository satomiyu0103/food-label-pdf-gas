# Python / uv
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
.envrc

# ロックファイルはコミットする（uv.lock / pnpm-lock.yaml 等は除外しない）

# Ruff / 型チェック / テスト
.ruff_cache/
.mypy_cache/
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# 環境変数・秘密情報（絶対に Git にコミットしない）
config/.env
config/.env.*
!config/.env.example
config/credentials.json
config/token.json
config/*.pem
config/*.key
.env
.env.*
!.env.example
*.local
secrets/
doc/Information.md

# ランタイムデータ（実行時に生成されるファイル）
data/
logs/
*.log

# Node.js / pnpm（GAS + clasp 利用時。同一リポジトリに追加した場合）
node_modules/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# clasp（認証情報のみ除外。.clasp.json は scriptId のためコミット可）
.clasprc.json

# Django 等を採用した場合のよくある生成物
db.sqlite3
*.sqlite3
local_settings.py
staticfiles/
media/

# エディタ・OS（.vscode/settings.json はリポジトリで共有するため除外しない）
.idea/
*.swp
*~
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# その他
.cache/
*.bak
