# ============================================================
# 環境変数テンプレート（キー名のみ。値は config/.env に記入）
# GAS 本番では Script Properties を使用。clasp ローカル開発用。
# ============================================================

# Gemini API
# GEMINI_API_KEY=

# Slack Incoming Webhook
# SLACK_WEBHOOK_URL=

# Google ドライブ フォルダ ID
# DRIVE_INPUT_FOLDER_ID=
# DRIVE_PROCESSED_FOLDER_ID=
# DRIVE_ERROR_FOLDER_ID=

# スプレッドシート ID
# URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
# 取得: 対象スプレッドシートを開き UI「商品DB シートを作成」→ ログの SPREADSHEET_ID= を転記
# 手順: doc/reference/setup/gas-clasp-pnpm.md
# SPREADSHEET_ID=

# デバッグ用（GAS エディタで debugPocExtractPdf / debugProcessPdf 実行時）
# Drive URL: https://drive.google.com/file/d/{DEBUG_PDF_FILE_ID}/view
# DEBUG_PDF_FILE_ID=
